{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GiftWrapper",
  "version": "1.0.0",
  "identifier": "com.okagentdigital.giftwrapper",
  "build": {
    "frontendDist": "../dist",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Gift Wrapper",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}